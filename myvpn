for N in $LIST; do
TAG=$(node_tag_by_index "$N")
[ -n "$TAG" ] && echo "$TAG" >> "$BASE/backup_profile_nodes.json"
done
echo custom > "$BASE/backup_profile_type"
apply
;;

3)
