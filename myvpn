preproxy_menu() { while true; do echo ""; echo "Preproxy"; echo "1) Disable"; echo "2) Select node"; echo "0) Back"; echo ""; read -p "Select option: " P; case "$P" in 1) rm -f "$BASE/preproxy_node"; apply ;; 2) echo ""; echo "Available nodes:"; node_list; echo ""; read -p "Node: " N; TAG=$(node_tag_by_index "$N"); echo "$TAG" > "$BASE/preproxy_node"; apply ;; 0) return ;; *) echo "Invalid selection" ;; esac; done }

nodes_menu() { while true; do echo ""; echo "Nodes"; echo "1) List nodes"; echo "2) TCP test nodes"; echo "3) Preproxy"; echo "0) Back"; echo ""; read -p "Select: " N; case "$N" in 1) node_list; read -p "Press Enter..." ;; 2) tcp_test ;; 3) preproxy_menu ;; 0) return ;; *) echo "Invalid selection" ;; esac; done }

rules_menu() { while true; do echo ""; echo "Rules (direct whitelist)"; echo "1) Show rules"; echo "2) Add rule"; echo "3) Delete rule"; echo "0) Back"; echo ""; read -p "Select: " R; case "$R" in 1) nl "$RULES"; read -p "Press Enter..." ;; 2) read -p "Enter domain or CIDR: " V; echo "$V" >> "$RULES"; apply ;; 3) nl "$RULES"; read -p "Line to delete: " L; sed -i "${L}d" "$RULES"; apply ;; 0) return ;; *) echo "Invalid selection" ;; esac; done }

subs_menu() { while true; do echo ""; echo "Subscriptions"; echo "1) Show"; echo "2) Add"; echo "3) Delete"; echo "4) Update now"; echo "0) Back"; echo ""; read -p "Select: " S; case "$S" in 1) nl "$SUBS"; read -p "Press Enter..." ;; 2) read -p "Enter subscription URL: " U; echo "$U" >> "$SUBS" ;; 3) nl "$SUBS"; read -p "Line: " L; sed -i "${L}d" "$SUBS" ;; 4) /usr/bin/myvpn-update; apply ;; 0) return ;; *) echo "Invalid selection" ;; esac; done }

# ================= MAIN MENU =================

while true
do

echo ""
echo "MYVPN"
echo "1) Status"
echo "2) State"
echo "3) Primary"
echo "4) Backup"
echo "5) Failover"
echo "6) Nodes"
echo "7) Rules"
echo "8) Subscriptions"
echo "9) Advanced"
echo "10) DNS"
echo "11) Core"
echo "0) Exit"
echo ""

read -p "Select option: " CH

case "$CH" in

1) show_status ;;
2) state_menu ;;
3) primary_menu ;;
4) backup_menu ;;
5) failover_menu ;;
6) nodes_menu ;;
7) rules_menu ;;
8) subs_menu ;;
9) advanced_menu ;;
10) dns_menu ;;
11) core_menu ;;
0) exit 0 ;;
*) echo "Invalid selection" ;;

esac

done
