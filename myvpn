while true
do
echo ""
echo "Backup profile"
echo "1) Single node"
echo "2) URLTest group"
echo "3) URLTest settings"
echo "0) Back"
echo ""

read -p "Select option: " B

case "$B" in

1)
echo ""
echo "Available nodes:"
node_list
echo ""
read -p "Node: " N
[ "$N" = "0" ] && continue
TAG=$(node_tag_by_index "$N")
echo single > "$BASE/backup_profile_type"
echo "$TAG" > "$BASE/backup_node"
